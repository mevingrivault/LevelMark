{
  "name": "levelmark",
  "version": "1.0.7",
  "description": "Cross-platform desktop app for batch watermarking, renaming, and WebP export.",
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:mac": "npm run build && electron-builder --mac --arm64",
    "build:win": "npm run prepare:sharp:win && npm run build && electron-builder --win --x64 --publish never",
    "build:installers": "npm run build && electron-builder --mac --arm64 --publish never && npm run prepare:sharp:win && electron-builder --win --x64 --publish never",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prepare:sharp:win": "npm install --include=optional --os=win32 --cpu=x64 sharp"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "cross-env": "^10.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.leveltech.levelmark",
    "productName": "LevelMark",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mevingrivault",
        "repo": "LevelMark"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  }
}
